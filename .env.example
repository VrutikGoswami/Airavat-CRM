# ---------------------------------------------------------------------------
# Airavat CRM — environment configuration
#
# The app runs out of the box in DEMO MODE with in-memory sample data and no
# backend. Leave these unset to explore the UI. Fill them in to connect the
# production Supabase + WhatsApp stack (see README).
# ---------------------------------------------------------------------------

# Set to "supabase" to use the live backend instead of the in-memory demo store.
# When "supabase", the three Supabase vars below are REQUIRED — the app loads
# all CRM data from the database and subscribes to Realtime for live updates.
NEXT_PUBLIC_DATA_MODE=demo

# --- Supabase --------------------------------------------------------------
# Project URL + anon (publishable) key. The anon key is safe to expose to the
# browser; row-level security governs what it can read/write. Never hardcode
# these — they are read from the environment only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Used by the WhatsApp webhook (to
# write incoming messages) and the public share page (to read a quotation).
SUPABASE_SERVICE_ROLE_KEY=

# --- Meta WhatsApp Business Cloud API --------------------------------------
# Server-only secrets. Configure in the Meta App dashboard.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# You choose this string; it must match the value entered in the Meta webhook UI.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-a-long-random-string
# Optional: verify webhook payload signatures (X-Hub-Signature-256).
WHATSAPP_APP_SECRET=

# --- Optional: n8n background automations ----------------------------------
N8N_WEBHOOK_URL=
